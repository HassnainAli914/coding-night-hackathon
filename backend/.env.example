# ─── Server ───────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Supabase ─────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# JWT secret from Supabase Dashboard → Settings → API → JWT Secret
JWT_SECRET=your-supabase-jwt-secret

# ─── CORS ─────────────────────────────────────────
# Comma-separated origins allowed to access the API
CORS_ORIGIN=http://localhost:8081,http://localhost:19006,exp://localhost:8081

# ─── Rate Limiting ────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Logging ──────────────────────────────────────
LOG_LEVEL=debug
